---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  hero?: boolean;
}
const { title, description = '面向中文读者的经济金融政策知识博客，个人学习整理与原创评论', hero = false } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · HappyColumbia</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />
  </head>

  <body class={`min-h-screen antialiased font-sans text-stone-900 ${hero ? 'bg-[#061828]' : 'bg-stone-50'}`}>

    <!-- ── Header ─────────────────────────────────────── -->
    <header
      id="site-header"
      data-hero={hero ? "true" : "false"}
      class="sticky top-0 z-50 transition-all duration-300 border-b site-header"
    >
      <div class="max-w-6xl mx-auto px-4 sm:px-5 py-3 sm:py-4 flex items-center justify-between gap-4">

        <!-- Logo -->
        <a href="/" class="no-underline leading-tight group shrink-0">
          <div class="logo-main font-display font-semibold tracking-tight text-lg transition-colors">
            HappyColumbia
          </div>
          <div class="logo-sub hidden sm:block text-[10px] tracking-widest uppercase mt-0.5">
            经济 · 金融 · 政策
          </div>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-1 text-sm shrink-0">
          {[
            { href: '/about-sipa/', label: '关于 SIPA' },
            { href: '/#courses', label: '专题笔记' },
            { href: '/career/', label: '求职分享' },
            { href: '/research/', label: '金融投研' },
            { href: '/alumni/', label: 'SIPA校友圈' },
            { href: '/join/',    label: '一起做这件事' },
          ].map(({ href, label }) => (
            <a href={href} class="nav-link px-3 py-1.5 rounded-md text-xs sm:text-sm transition-colors no-underline">
              {label}
            </a>
          ))}
          <a href="/join/" class="nav-cta ml-1 px-4 py-1.5 rounded-full text-xs sm:text-sm font-medium border transition-all no-underline">
            联系我
          </a>
        </nav>

        <!-- Mobile Hamburger -->
        <button id="mobile-menu-btn" aria-label="打开菜单"
          class="md:hidden flex flex-col justify-center items-center w-9 h-9 gap-1.5 rounded-md transition-colors ham-btn">
          <span id="ham-1" class="ham-line block w-5 h-0.5 rounded transition-all duration-300"></span>
          <span id="ham-2" class="ham-line block w-5 h-0.5 rounded transition-all duration-300"></span>
          <span id="ham-3" class="ham-line block w-5 h-0.5 rounded transition-all duration-300"></span>
        </button>
      </div>

      <!-- Mobile Menu Drawer -->
      <div id="mobile-menu" class="md:hidden hidden border-t border-stone-200/20 bg-white">
        <nav class="flex flex-col px-5 py-4 gap-1">
          {[
            { href: '/about-sipa/', label: '关于 SIPA' },
            { href: '/#courses',   label: '专题笔记' },
            { href: '/career/',    label: '求职分享' },
            { href: '/research/',  label: '金融投研' },
            { href: '/alumni/',    label: 'SIPA校友圈' },
            { href: '/join/',      label: '一起做这件事' },
          ].map(({ href, label }) => (
            <a href={href} class="block px-3 py-2.5 rounded-lg text-stone-700 text-sm font-medium hover:bg-stone-100 hover:text-columbia-navy transition-colors no-underline">
              {label}
            </a>
          ))}
          <a href="/join/" class="mt-2 block text-center px-4 py-2.5 rounded-full text-sm font-semibold border border-columbia-navy text-columbia-navy hover:bg-columbia-navy hover:text-white transition-all no-underline">
            联系我
          </a>
        </nav>
      </div>
    </header>

    <style>
      /* ── Default (non-hero) ── */
      .site-header                          { background: white; border-color: rgb(231,229,228); }
      .site-header .logo-main               { color: rgb(28,25,23); }
      .site-header .logo-sub                { color: rgb(168,162,158); }
      .site-header .nav-link                { color: rgb(87,83,78); }
      .site-header .nav-link:hover          { background: rgb(245,245,244); color: rgb(28,25,23); }
      .site-header .nav-cta                 { border-color: rgb(214,211,209); color: rgb(68,64,60); }
      .site-header .nav-cta:hover           { border-color: #0B2C56; color: #0B2C56; }
      .site-header .ham-line                { background: rgb(68,64,60); }
      .site-header .ham-btn:hover           { background: rgb(245,245,244); }

      /* ── Hero top ── */
      .site-header[data-hero="true"]                    { background: transparent; border-color: rgba(255,255,255,0.1); }
      .site-header[data-hero="true"] .logo-main         { color: white; }
      .site-header[data-hero="true"] .logo-sub          { color: rgba(255,255,255,0.5); }
      .site-header[data-hero="true"] .nav-link          { color: rgba(255,255,255,0.8); }
      .site-header[data-hero="true"] .nav-link:hover    { background: rgba(255,255,255,0.1); color: white; }
      .site-header[data-hero="true"] .nav-cta           { border-color: rgba(255,255,255,0.4); color: white; }
      .site-header[data-hero="true"] .nav-cta:hover     { background: white; color: #0B2C56; }
      .site-header[data-hero="true"] .ham-line          { background: white; }
      .site-header[data-hero="true"] .ham-btn:hover     { background: rgba(255,255,255,0.1); }

      /* ── Hero scrolled ── */
      .site-header[data-hero="true"][data-scrolled="true"]                 { background: rgba(255,255,255,0.96); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-color: rgb(231,229,228); }
      .site-header[data-hero="true"][data-scrolled="true"] .logo-main      { color: rgb(28,25,23); }
      .site-header[data-hero="true"][data-scrolled="true"] .logo-sub       { color: rgb(168,162,158); }
      .site-header[data-hero="true"][data-scrolled="true"] .nav-link       { color: rgb(87,83,78); }
      .site-header[data-hero="true"][data-scrolled="true"] .nav-link:hover { background: rgb(245,245,244); color: rgb(28,25,23); }
      .site-header[data-hero="true"][data-scrolled="true"] .nav-cta        { border-color: rgb(214,211,209); color: rgb(68,64,60); }
      .site-header[data-hero="true"][data-scrolled="true"] .nav-cta:hover  { border-color: #0B2C56; color: #0B2C56; }
      .site-header[data-hero="true"][data-scrolled="true"] .ham-line       { background: rgb(68,64,60); }
      .site-header[data-hero="true"][data-scrolled="true"] .ham-btn:hover  { background: rgb(245,245,244); }
    </style>

    <!-- ── Main ───────────────────────────────────────── -->
    <main class={hero ? '' : 'max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14'}>
      <slot />
    </main>

    <!-- ── Footer ────────────────────────────────────── -->
    <footer class="bg-columbia-navy text-white/60 mt-0">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 md:py-14 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
        <div>
          <p class="font-display font-semibold text-white text-lg">HappyColumbia</p>
          <p class="mt-2 text-sm leading-relaxed">
            经济 · 金融 · 政策<br />个人原创知识博客
          </p>
          <p class="mt-4 text-xs text-white/40 leading-relaxed">
            纯公益，不盈利、不收费、无广告。<br />
            内容为个人学习整理与原创评论，与任何机构无关联。
          </p>
        </div>
        <div>
          <p class="text-white font-medium text-sm uppercase tracking-widest mb-4">导航</p>
          <ul class="space-y-2 text-sm">
            <li><a href="/about-sipa/" class="hover:text-white transition-colors no-underline">关于 SIPA</a></li>
            <li><a href="/#courses" class="hover:text-white transition-colors no-underline">课程笔记</a></li>
            <li><a href="/career/" class="hover:text-white transition-colors no-underline">求职经验分享</a></li>
            <li><a href="/research/" class="hover:text-white transition-colors no-underline">金融投研</a></li>
            <li><a href="/alumni/" class="hover:text-white transition-colors no-underline">SIPA校友圈</a></li>
            <li><a href="/join/"   class="hover:text-white transition-colors no-underline">一起做这件事</a></li>
          </ul>
        </div>
        <div>
          <p class="text-white font-medium text-sm uppercase tracking-widest mb-4">联系</p>
          <ul class="space-y-2 text-sm">
            <li>
              <a href="mailto:yh3811@columbia.edu" class="hover:text-white transition-colors no-underline">
                yh3811@columbia.edu
              </a>
            </li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10 max-w-6xl mx-auto px-4 sm:px-6 py-4 sm:py-5 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 text-xs text-white/30">
        <span class="shrink-0">© 2025 HappyColumbia</span>
        <span class="leading-relaxed text-right sm:text-right text-left">内容受国际资深教授、著名投资家与银行家启发，由 AI 辅助整理，不代表任何机构立场。若内容涉及版权，请联系删除。</span>
      </div>
    </footer>

  </body>

  <!-- ── Mobile menu toggle ───────────────────────── -->
  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const h1 = document.getElementById('ham-1');
    const h2 = document.getElementById('ham-2');
    const h3 = document.getElementById('ham-3');
    let open = false;
    btn?.addEventListener('click', () => {
      open = !open;
      menu?.classList.toggle('hidden', !open);
      if (h1 && h2 && h3) {
        h1.style.transform = open ? 'translateY(8px) rotate(45deg)' : '';
        h2.style.opacity   = open ? '0' : '1';
        h3.style.transform = open ? 'translateY(-8px) rotate(-45deg)' : '';
      }
    });
    // close when nav link clicked
    menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      open = false;
      menu.classList.add('hidden');
      if (h1 && h2 && h3) { h1.style.transform = h3.style.transform = ''; h2.style.opacity = '1'; }
    }));
  </script>

  <!-- ── Header scroll effect ───────────────────────── -->
  <script>
    const header = document.getElementById('site-header');
    if (header) {
      const update = () => {
        if (window.scrollY > 60) {
          header.dataset.scrolled = 'true';
        } else {
          delete header.dataset.scrolled;
        }
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    }
  </script>
</html>
