---
import Base from '../../layouts/Base.astro';
---

<Base title="SIPA校友圈——建设中">

<style>
  /* ── Hero ── */
  .alumni-hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #0B2C56;
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  /* globe glow */
  .alumni-hero::before {
    content: '';
    position: absolute;
    top: -10%; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(91,155,213,0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  /* bottom glow */
  .alumni-hero::after {
    content: '';
    position: absolute;
    bottom: -5%; right: -10%;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(184,134,11,0.10) 0%, transparent 60%);
    pointer-events: none;
  }

  /* ── animated badge ── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 999px;
    padding: 0.4rem 1.1rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    backdrop-filter: blur(8px);
  }
  .badge .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #f0c040;
    animation: pulse 2.2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 rgba(240,192,64,0.5); }
    50% { opacity: 0.75; transform: scale(0.88); box-shadow: 0 0 0 5px rgba(240,192,64,0); }
  }

  /* ── title ── */
  .main-title {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.3rem;
    position: relative;
  }
  .title-sub {
    display: block;
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    font-weight: 400;
    font-style: italic;
    color: rgba(255,255,255,0.45);
    margin-top: 0.3rem;
  }

  .hero-desc {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.8;
    max-width: 500px;
    margin: 0 auto 3rem;
  }

  /* ── city tags ── */
  .city-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
    margin-bottom: 3.5rem;
  }
  .city-tag {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 999px;
    padding: 0.3rem 0.9rem;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.6);
  }
  .city-tag.active {
    background: rgba(91,155,213,0.2);
    border-color: rgba(91,155,213,0.5);
    color: #a8d4f5;
  }

  /* ── CTA buttons ── */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: center;
    margin-bottom: 5rem;
  }

  /* ── wave ── */
  .wave { display: block; width: 100%; margin-top: -2px; }

  /* ── Features section ── */
  .features-section {
    background: #f8f7f4;
    padding: 5rem 1.5rem;
  }
  .features-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #aaa;
    text-align: center;
    margin-bottom: 0.7rem;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #0B2C56;
    text-align: center;
    margin-bottom: 0.8rem;
  }
  .section-sub {
    text-align: center;
    font-size: 0.9375rem;
    color: #888;
    max-width: 420px;
    margin: 0 auto 3.5rem;
    line-height: 1.7;
  }

  /* 2×2 feature grid */
  .feat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  @media (max-width: 600px) {
    .feat-grid { grid-template-columns: 1fr; }
  }
  .feat-card {
    background: #fff;
    border: 1px solid #e8e3db;
    border-radius: 18px;
    padding: 2rem 1.8rem;
    position: relative;
    overflow: hidden;
    transition: box-shadow .2s, transform .2s;
  }
  .feat-card:hover {
    box-shadow: 0 8px 32px rgba(11,44,86,0.09);
    transform: translateY(-2px);
  }
  .feat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    border-radius: 18px 18px 0 0;
  }
  .feat-card.c1::before { background: linear-gradient(90deg, #5B9BD5, #a8d4f5); }
  .feat-card.c2::before { background: linear-gradient(90deg, #B8860B, #f0c040); }
  .feat-card.c3::before { background: linear-gradient(90deg, #27ae60, #7ed9a0); }
  .feat-card.c4::before { background: linear-gradient(90deg, #8B5CF6, #c4b5fd); }

  .feat-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
    margin-bottom: 1.2rem;
  }
  .feat-card.c1 .feat-icon { background: #e8f3fc; }
  .feat-card.c2 .feat-icon { background: #fdf9ee; }
  .feat-card.c3 .feat-icon { background: #f0faf4; }
  .feat-card.c4 .feat-icon { background: #f5f0ff; }

  .feat-title {
    font-weight: 700;
    font-size: 1.0625rem;
    color: #0B2C56;
    margin-bottom: 0.6rem;
  }
  .feat-desc {
    font-size: 0.875rem;
    color: #777;
    line-height: 1.7;
    margin-bottom: 1.2rem;
  }
  .feat-items {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .feat-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: #555;
  }
  .feat-item::before {
    content: '';
    width: 5px; height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .feat-card.c1 .feat-item::before { background: #5B9BD5; }
  .feat-card.c2 .feat-item::before { background: #B8860B; }
  .feat-card.c3 .feat-item::before { background: #27ae60; }
  .feat-card.c4 .feat-item::before { background: #8B5CF6; }

  /* ── CTA section ── */
  .cta-section {
    background: #0B2C56;
    padding: 5rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 300px;
    background: radial-gradient(ellipse, rgba(91,155,213,0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.8rem;
    position: relative;
  }
  .cta-section p {
    color: rgba(255,255,255,0.6);
    font-size: 0.9375rem;
    max-width: 380px;
    margin: 0 auto 2.5rem;
    line-height: 1.75;
    position: relative;
  }
</style>

<!-- ═══════════════════════════ HERO ═══════════════════════════ -->
<section class="alumni-hero">
  <div class="relative z-10 flex flex-col items-center w-full max-w-2xl mx-auto">

    <div class="badge">
      <span class="dot"></span>
      即将上线 · Coming Soon
    </div>

    <h1 class="main-title">SIPA 校友圈</h1>
    <p style="font-family:'Playfair Display',serif; font-style:italic; font-size:1.1rem; color:rgba(255,255,255,0.38); margin-top:-0.8rem; margin-bottom:1.8rem; letter-spacing:0.02em;">Columbia SIPA Alumni Community</p>

    <p class="hero-desc">
      一个专属于 SIPA 在读生与校友的社区——<br/>
      在这里找到同频的人，共同面对求职、职场和人生的每一个岔路口。
    </p>

    <!-- City nodes -->
    <div class="city-row">
      <span class="city-tag active">🗽 纽约</span>
      <span class="city-tag active">🏙 北京</span>
      <span class="city-tag active">🌆 上海</span>
      <span class="city-tag active">🌃 香港</span>
      <span class="city-tag">新加坡</span>
      <span class="city-tag">伦敦</span>
      <span class="city-tag">华盛顿 DC</span>
      <span class="city-tag">+ 更多城市</span>
    </div>

    <div class="cta-row">
      <a href="/join/"
         class="no-underline px-7 py-3 bg-white text-columbia-navy font-semibold text-sm rounded-full
                hover:bg-columbia-light transition-all shadow-lg hover:-translate-y-0.5">
        我想参与建设 →
      </a>
      <a href="/#courses"
         class="no-underline px-7 py-3 bg-white/10 border border-white/20 text-white text-sm rounded-full
                hover:bg-white/15 transition-all">
        先看看课程笔记
      </a>
    </div>

  </div>

  <!-- wave -->
  <div class="absolute bottom-[-2px] left-0 right-0" style="z-index:3;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="display:block;">
      <path d="M0 60L1440 60L1440 24C1200 54 960 2 720 24C480 46 240 6 0 24L0 60Z" fill="#f8f7f4"/>
    </svg>
  </div>
</section>

<!-- ═══════════════════════════ FEATURES ═══════════════════════ -->
<section class="features-section">
  <div class="features-inner">

    <p class="section-label">正在规划的功能</p>
    <h2 class="section-title">我们想一起做的事</h2>
    <p class="section-sub">这个社区还在搭建中，但方向已经很清晰。</p>

    <div class="feat-grid">

      <!-- 城市活动 -->
      <div class="feat-card c1">
        <div class="feat-icon">🌆</div>
        <div class="feat-title">城市聚会 & 活动</div>
        <div class="feat-desc">在你所在的城市，找到一起吃饭、聊天、内推的 SIPA 朋友。</div>
        <div class="feat-items">
          <span class="feat-item">定期线下 Meetup</span>
          <span class="feat-item">行业分享沙龙</span>
          <span class="feat-item">新生入学接待</span>
          <span class="feat-item">毕业季告别聚</span>
        </div>
      </div>

      <!-- 职场内推 -->
      <div class="feat-card c2">
        <div class="feat-icon">🤝</div>
        <div class="feat-title">职场内推 & 资源对接</div>
        <div class="feat-desc">金融、咨询、政策、科技——校友互帮互助，让第一份工作更顺利。</div>
        <div class="feat-items">
          <span class="feat-item">内推信息聚合</span>
          <span class="feat-item">简历帮改 & 模拟面试</span>
          <span class="feat-item">行业导师 1v1</span>
          <span class="feat-item">岗位信息互通</span>
        </div>
      </div>

      <!-- 经验交流 -->
      <div class="feat-card c3">
        <div class="feat-icon">💬</div>
        <div class="feat-title">经验交流 & 内容共建</div>
        <div class="feat-desc">申请攻略、选课心得、求职复盘——真实经历比任何攻略都有价值。</div>
        <div class="feat-items">
          <span class="feat-item">SIPA 申请经验库</span>
          <span class="feat-item">课程口碑评价</span>
          <span class="feat-item">求职真实记录</span>
          <span class="feat-item">生活避坑指南</span>
        </div>
      </div>

      <!-- 全球网络 -->
      <div class="feat-card c4">
        <div class="feat-icon">🌐</div>
        <div class="feat-title">全球校友网络</div>
        <div class="feat-desc">连接分布在世界各地的 SIPA 人，把校友资源真正用起来，而不只是停留在 LinkedIn。</div>
        <div class="feat-items">
          <span class="feat-item">按城市 / 行业搜索校友</span>
          <span class="feat-item">跨地区信息互通</span>
          <span class="feat-item">创业 & 副业协作</span>
          <span class="feat-item">长期关系维护</span>
        </div>
      </div>

    </div>

  </div>
</section>

<!-- ═══════════════════════════ CTA ════════════════════════════ -->
<section class="cta-section">
  <div class="relative z-10">
    <h2>一起把这件事做起来</h2>
    <p>
      如果你是 SIPA 在读生或校友，欢迎联系我——<br/>
      哪怕只是交个朋友，也很好。
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href="/join/"
         class="no-underline px-7 py-3 bg-white text-columbia-navy font-semibold text-sm rounded-full
                hover:bg-columbia-light transition-all shadow-lg hover:-translate-y-0.5">
        联系我 →
      </a>
      <a href="/"
         class="no-underline px-7 py-3 bg-white/10 border border-white/20 text-white text-sm rounded-full
                hover:bg-white/15 transition-all">
        返回首页
      </a>
    </div>
  </div>
</section>

</Base>
