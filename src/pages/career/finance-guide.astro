              { role: '券商研究所', pay: '中等偏低', pressure: '★★★☆☆', hard: '★★★☆☆', exit: '公募基金 / 行业分析' },
              { role: 'PE（应届/直招）', pay: '高', pressure: '★★★★★', hard: '★★★★★', exit: '基金合伙人 / 企业高管' },
              { role: 'VC（初级）', pay: '中等偏高', pressure: '★★★★☆', hard: '★★★★★', exit: '高级投资人 / 创业' },
              { role: '公募基金研究员', pay: '中等偏高', pressure: '★★★★☆', hard: '★★★★☆', exit: '基金经理 / 私募' },
