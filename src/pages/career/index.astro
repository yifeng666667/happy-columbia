---
import Base from '../../layouts/Base.astro';

const chapters = [
  {
    num: '01',
    href: '/career/chapter-1/',
    title: '如何找到自己热爱的方向',
    desc: 'AI 时代 + 留学生身份 + 回国或留美——在投出第一份简历之前，先建立一套完整的坐标系。写给经济学/商科本科 + 海外名校金融硕士背景的毕业生。',
    tags: ['AI 时代', '回国 vs 留美', '行业选择', '热爱'],
    date: '2026-04-09',
    readTime: '约 25 分钟',
    status: 'published',
  },
  {
    num: '02',
    href: '/career/chapter-2/',
    title: '求职时间线——什么时候做什么，一步都不能错',
    desc: '美国最早，香港居中，大陆最晚。三条时间轴、三套节奏——从暑期实习到秋招春招的完整作战地图，结合 2025–2026 年市场真实状况写给 SIPA 的你。',
    tags: ['时间线', '秋招', '美国 / 香港 / 大陆', '暑期转正'],
    date: '2026-04-09',
    readTime: '约 20 分钟',
    status: 'published',
  },
  {
    num: '03',
    href: '/career/resume-guide/',
    title: '简历与实习——如何在最短时间内建立最有效的履历',
    desc: '250份简历、60次面试、横跨中美与互联网金融咨询——从求职者和面试官双重视角，讲清楚校招求职的底层逻辑。一份工作，一份简历。',
    tags: ['简历', '实习策略', '中美职场', '面试官视角'],
    date: '2026-04-10',
    readTime: '约 30 分钟',
    status: 'published',
  },
  {
    num: '04',
    href: '#',
    title: '面试与笔试——如何在高压环境中展示真实的自己',
    desc: '技术面、行为面、案例面的准备方法，以及如何在面试中既展示能力，又保持真实。',
    tags: ['面试', '笔试', '案例分析'],
    date: '',
    readTime: '',
    status: 'coming',
  },
];
---

<Base title="求职经验分享" hero={true}>

  <!-- ── Hero ──────────────────────────────────────── -->
  <section class="career-hero relative min-h-[62vh] flex flex-col justify-end overflow-hidden">

    <!-- Background image + overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1800&q=85"
        alt=""
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0" style="background: linear-gradient(160deg, rgba(6,24,40,0.82) 0%, rgba(11,44,86,0.78) 50%, rgba(4,16,32,0.88) 100%);"></div>
    </div>

    <!-- Text -->
    <div class="relative z-10 max-w-5xl mx-auto px-6 w-full pb-20 pt-32">
      <p class="text-[11px] uppercase tracking-[0.3em] text-white/50 mb-3">Career Series</p>
      <h1 class="font-display font-bold text-white leading-tight mb-4"
          style="font-size: clamp(2rem, 5vw, 3.5rem);">
        求职经验分享
      </h1>
      <p class="text-white/65 text-base leading-relaxed mb-7 max-w-xl">
        从 SIPA 到职场的真实路径——整理自己和同学们在求职路上的经验、教训、思路和资源。<br/>
        写给经济学 / 商科背景、有海外留学经历、正在面对「回国还是留美」选择的年轻人。
      </p>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-white/40">
        <span class="flex items-baseline gap-1.5">
          <span class="text-white/80 font-bold text-xl">3</span>
          <span>篇已发布</span>
        </span>
        <span class="text-white/20">·</span>
        <span class="flex items-baseline gap-1.5">
          <span class="text-white/40 font-bold text-xl">1</span>
          <span>篇即将上线</span>
        </span>
        <span class="text-white/20">·</span>
        <span>持续更新中</span>
      </div>
    </div>

    <!-- Wave transition -->
    <div class="absolute bottom-[-2px] left-0 right-0" style="z-index:3;">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none"
           xmlns="http://www.w3.org/2000/svg" style="display:block;">
        <path d="M0 60L1440 60L1440 24C1200 54 960 2 720 24C480 46 240 6 0 24L0 60Z"
              fill="#f8f7f4"/>
      </svg>
    </div>
  </section>

  <!-- ── Content wrapper ───────────────────────────── -->
  <div class="bg-[#f8f7f4] w-full">
  <div class="max-w-5xl mx-auto px-6 pt-14 pb-4">

  <!-- ── Chapter List ────────────────────────────── -->
  <div class="space-y-5 mb-16">
    {chapters.map((ch) => (
      <div class={`relative group ${ch.status === 'coming' ? 'opacity-55' : ''}`}>
        {ch.status === 'published' ? (
          <a
            href={ch.href}
            class="card-lift block bg-white border border-stone-200 rounded-2xl p-7 no-underline text-stone-900 hover:border-columbia-blue transition-all"
          >
            <div class="flex items-start gap-5">
              <div class="shrink-0 w-12 h-12 rounded-xl bg-columbia-navy flex items-center justify-center">
                <span class="font-display font-bold text-white text-sm">{ch.num}</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-4 flex-wrap">
                  <h2 class="font-display font-bold text-lg text-stone-900 group-hover:text-columbia-navy transition-colors leading-snug">
                    {ch.title}
                  </h2>
                  {ch.date && (
                    <span class="shrink-0 text-[11px] text-stone-400 mt-0.5">{ch.date}</span>
                  )}
                </div>
                <p class="mt-2 text-sm text-stone-500 leading-relaxed max-w-2xl">{ch.desc}</p>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  {ch.tags.map((tag) => (
                    <span class="text-[10px] bg-columbia-light text-columbia-navy font-medium px-2.5 py-0.5 rounded-full">
                      {tag}
                    </span>
                  ))}
                  {ch.readTime && (
                    <span class="text-[11px] text-stone-400 ml-1">{ch.readTime}</span>
                  )}
                </div>
              </div>
              <span class="shrink-0 text-columbia-blue opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all text-xl mt-2">→</span>
            </div>
          </a>
        ) : (
          <div class="bg-white border border-dashed border-stone-200 rounded-2xl p-7">
            <div class="flex items-start gap-5">
              <div class="shrink-0 w-12 h-12 rounded-xl bg-stone-100 flex items-center justify-center">
                <span class="font-display font-bold text-stone-400 text-sm">{ch.num}</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h2 class="font-display font-bold text-lg text-stone-400 leading-snug">{ch.title}</h2>
                  <span class="text-[10px] bg-stone-100 text-stone-400 font-medium px-2.5 py-0.5 rounded-full">
                    即将上线
                  </span>
                </div>
                <p class="mt-2 text-sm text-stone-400 leading-relaxed max-w-2xl">{ch.desc}</p>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  {ch.tags.map((tag) => (
                    <span class="text-[10px] bg-stone-100 text-stone-400 font-medium px-2.5 py-0.5 rounded-full">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        )}
      </div>
    ))}
  </div>

  <!-- ── Industry Deep-Dives ──────────────────────────── -->
  <div class="mb-10">
    <p class="text-[10px] uppercase tracking-[0.2em] text-stone-400 font-medium mb-4">行业深度解析</p>

    <!-- Finance Guide -->
    <a
      href="/career/finance-guide/"
      class="card-lift block bg-columbia-navy border border-columbia-navy/20 rounded-2xl p-7 no-underline group"
    >
      <div class="flex items-start gap-5">
        <div class="shrink-0 w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h12A2.25 2.25 0 0020.25 14.25V3M3.75 3h16.5M3.75 3H2.25M20.25 3H21.75M12 3v13.5m0 0l-3-3m3 3l3-3" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-4 flex-wrap">
            <h2 class="font-display font-bold text-lg text-white group-hover:text-columbia-light transition-colors leading-snug">
              金融行业方向与岗位深度解析
            </h2>
            <span class="shrink-0 text-[11px] text-white/40 mt-0.5">2026-04-10</span>
          </div>
          <p class="mt-2 text-sm text-white/65 leading-relaxed max-w-2xl">
            一级 vs 二级市场、买方 vs 卖方、投行 IBD / S&T / Research / PE / VC / 公募——从薪酬、压力到招聘难度，帮你在投简历前看清金融行业的全景地图。
          </p>
          <div class="mt-3 flex flex-wrap items-center gap-2">
            {['一级市场', '二级市场', '买方 / 卖方', 'IBD · PE · VC · 公募', '薪酬对比', '仅供参考'].map((tag) => (
              <span class="text-[10px] bg-white/10 text-white/75 font-medium px-2.5 py-0.5 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        </div>
        <span class="shrink-0 text-white/40 opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all text-xl mt-2">→</span>
      </div>
    </a>

    <!-- Research Guide -->
    <a
      href="/career/research-guide/"
      class="card-lift block bg-stone-800 border border-stone-700 rounded-2xl p-7 no-underline group mt-4"
    >
      <div class="flex items-start gap-5">
        <div class="shrink-0 w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-4 flex-wrap">
            <h2 class="font-display font-bold text-lg text-white group-hover:text-stone-200 transition-colors leading-snug">
              券商研究所深度解析：研究员 · 机构销售 · 中后台
            </h2>
            <span class="shrink-0 text-[11px] text-white/40 mt-0.5">2026-04-10</span>
          </div>
          <p class="mt-2 text-sm text-white/65 leading-relaxed max-w-2xl">
            分仓佣金如何运转、公募费率新规冲击几何、研究员每天 8:30–23:30 在做什么——结合 2026 年市场行情，把券商研究所这行说透。
          </p>
          <div class="mt-3 flex flex-wrap items-center gap-2">
            {['分仓佣金', '公募新规', '研究员', '机构销售', '2026行情', '仅供参考'].map((tag) => (
              <span class="text-[10px] bg-white/10 text-white/75 font-medium px-2.5 py-0.5 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        </div>
        <span class="shrink-0 text-white/40 opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all text-xl mt-2">→</span>
      </div>
    </a>
  </div>

  <!-- ── Contribute CTA ─────────────────────────────── -->
  <section class="bg-columbia-navy rounded-2xl p-8 text-white text-center">
    <p class="font-display font-semibold text-lg mb-2">有你自己的求职故事？</p>
    <p class="text-white/60 text-sm leading-relaxed mb-5 max-w-md mx-auto">
      无论是成功还是失败的经验，都可能对后来者有巨大帮助。欢迎联系一起完善这个系列。
    </p>
    <a
      href="mailto:yh3811@columbia.edu"
      class="inline-block no-underline px-6 py-2.5 bg-white text-columbia-navy font-semibold text-sm rounded-full hover:bg-columbia-light transition-colors"
    >
      联系我 →
    </a>
  </section>

  </div><!-- end inner -->
  </div><!-- end full-width bg -->

</Base>
