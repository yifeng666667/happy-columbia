---
import Base from '../../layouts/Base.astro';

const chapters = [
  {
    num: '01',
    href: '/career/chapter-1/',
    title: '如何找到自己热爱的方向',
    desc: 'AI 时代 + 留学生身份 + 回国或留美——在投出第一份简历之前，先建立一套完整的坐标系。写给经济学/商科本科 + 海外名校金融硕士背景的毕业生。',
    tags: ['AI 时代', '回国 vs 留美', '行业选择', '热爱'],
    date: '2026-04-09',
    readTime: '约 25 分钟',
    status: 'published',
  },
  {
    num: '02',
    href: '/career/chapter-2/',
    title: '求职时间线——时机比努力更关键',
    desc: '美国最早，香港居中，大陆最晚。三条时间轴、三套节奏——从暑期实习到秋招春招的完整作战地图，结合 2025–2026 年市场真实状况写给 SIPA 的你。',
    tags: ['时间线', '秋招', '美国 / 香港 / 大陆', '暑期转正'],
    date: '2026-04-09',
    readTime: '约 20 分钟',
    status: 'published',
  },
  {
    num: '03',
    href: '/career/resume-guide/',
    title: '简历与实习——如何在最短时间内建立最有效的履历',
    desc: '250份简历、60次面试、横跨中美与互联网金融咨询——从求职者和面试官双重视角，讲清楚校招求职的底层逻辑。一份工作，一份简历。',
    tags: ['简历', '实习策略', '中美职场', '面试官视角'],
    date: '2026-04-10',
    readTime: '约 30 分钟',
    status: 'published',
  },
  {
    num: '04',
    href: '/career/chapter-4/',
    title: '面试与笔试——如何在高压环境中展示真实的自己',
    desc: '技术面、行为面、股票推荐、HireVue——四种关卡的准备逻辑，以及在高压下如何既展示能力，又不失去自己。结合 2025–2026 年市场真实情况。',
    tags: ['技术面', '行为面', 'HireVue', '股票推荐'],
    date: '2026-04-11',
    readTime: '约 22 分钟',
    status: 'published',
  },
];
---

<Base title="求职经验分享" hero={true}>

  <!-- ── Hero ──────────────────────────────────────── -->
  <section class="career-hero relative min-h-[62vh] flex flex-col justify-end overflow-hidden">

    <!-- Background image + overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1800&q=85"
        alt=""
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0" style="background: linear-gradient(160deg, rgba(6,24,40,0.82) 0%, rgba(11,44,86,0.78) 50%, rgba(4,16,32,0.88) 100%);"></div>
    </div>

    <!-- Text -->
    <div class="relative z-10 max-w-5xl mx-auto px-6 w-full pb-20 pt-32">
      <p class="text-[11px] uppercase tracking-[0.3em] text-white/50 mb-3">Career Series</p>
      <h1 class="font-display font-bold text-white leading-tight mb-4"
          style="font-size: clamp(2rem, 5vw, 3.5rem);">
        求职经验分享
      </h1>
      <p class="text-white/80 text-[1.05rem] leading-relaxed mb-3 max-w-xl">
        从 SIPA 到职场的真实路径，整理自己和同学们在求职路上的经验、教训、思路和资源。
      </p>
      <p class="text-white/45 text-sm leading-relaxed mb-7 max-w-lg">
        写给经济学 / 商科背景、有海外留学经历、正在面对「回国还是留美」选择的年轻人。
      </p>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-white/40">
        <span class="flex items-baseline gap-1.5">
          <span class="text-white/80 font-bold text-xl">4</span>
          <span>篇已发布</span>
        </span>
        <span class="text-white/20">·</span>
        <span>持续更新中</span>
      </div>
    </div>

    <!-- Wave transition -->
    <div class="absolute bottom-[-2px] left-0 right-0" style="z-index:3;">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none"
           xmlns="http://www.w3.org/2000/svg" style="display:block;">
        <path d="M0 60L1440 60L1440 24C1200 54 960 2 720 24C480 46 240 6 0 24L0 60Z"
              fill="#f8f7f4"/>
      </svg>
    </div>
  </section>

  <!-- ── Content wrapper ───────────────────────────── -->
  <div class="bg-[#f8f7f4] w-full">
  <div class="max-w-5xl mx-auto px-6 pt-14 pb-4">

  <!-- ── Industry Deep-Dives ──────────────────────────── -->
  <div class="mb-10">
    <div class="flex items-baseline gap-3 mb-6">
      <h2 class="font-display font-bold text-xl text-stone-800">行业深度解析</h2>
      <span class="text-[11px] text-stone-400 uppercase tracking-widest">Industry Guides</span>
    </div>

    <div class="grid md:grid-cols-2 gap-4">

      <!-- Finance Guide -->
      <a
        href="/career/finance-guide/"
        class="card-lift relative block rounded-2xl overflow-hidden no-underline group min-h-[220px]"
        style="background-image: url('https://images.unsplash.com/photo-1486325212027-8081e485255e?auto=format&fit=crop&w=1200&q=80'); background-size: cover; background-position: center bottom;"
      >
        <!-- Overlay -->
        <div class="absolute inset-0 transition-opacity duration-300"
             style="background: linear-gradient(160deg, rgba(8,20,50,0.88) 0%, rgba(11,44,86,0.80) 60%, rgba(5,15,40,0.75) 100%);"></div>
        <!-- Content -->
        <div class="relative z-10 p-7 h-full flex flex-col justify-between">
          <div>
            <p class="text-[10px] uppercase tracking-[0.25em] text-white/45 mb-3">Finance Guide · 2026-04-10</p>
            <h3 class="font-display font-bold text-xl text-white leading-snug mb-3 group-hover:text-columbia-light transition-colors">
              金融行业方向与<br/>岗位深度解析
            </h3>
            <p class="text-sm text-white/60 leading-relaxed">
              一级 vs 二级市场、买方 vs 卖方、IBD / PE / VC / 公募——帮你在投简历前看清金融全景地图。
            </p>
          </div>
          <div class="mt-5 flex flex-wrap items-center justify-between gap-2">
            <div class="flex flex-wrap gap-1.5">
              {['IBD · PE · VC', '薪酬对比', '买方 / 卖方'].map((tag) => (
                <span class="text-[10px] bg-white/12 text-white/70 font-medium px-2.5 py-0.5 rounded-full border border-white/10">
                  {tag}
                </span>
              ))}
            </div>
            <span class="text-white/40 group-hover:text-white/80 group-hover:translate-x-0.5 transition-all text-lg">→</span>
          </div>
        </div>
      </a>

      <!-- Research Guide -->
      <a
        href="/career/research-guide/"
        class="card-lift relative block rounded-2xl overflow-hidden no-underline group min-h-[220px]"
        style="background-image: url('https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?auto=format&fit=crop&w=1200&q=80'); background-size: cover; background-position: center;"
      >
        <!-- Overlay -->
        <div class="absolute inset-0 transition-opacity duration-300"
             style="background: linear-gradient(160deg, rgba(15,10,5,0.90) 0%, rgba(30,20,10,0.82) 60%, rgba(10,8,5,0.78) 100%);"></div>
        <!-- Content -->
        <div class="relative z-10 p-7 h-full flex flex-col justify-between">
          <div>
            <p class="text-[10px] uppercase tracking-[0.25em] text-white/45 mb-3">Research Guide · 2026-04-10</p>
            <h3 class="font-display font-bold text-xl text-white leading-snug mb-3 group-hover:text-stone-200 transition-colors">
              券商研究所深度解析<br/>研究员 · 机构销售 · 中后台
            </h3>
            <p class="text-sm text-white/60 leading-relaxed">
              分仓佣金如何运转、公募费率新规冲击几何、研究员 8:30–23:30 的真实日常。
            </p>
          </div>
          <div class="mt-5 flex flex-wrap items-center justify-between gap-2">
            <div class="flex flex-wrap gap-1.5">
              {['分仓佣金', '公募新规', '2026行情'].map((tag) => (
                <span class="text-[10px] bg-white/12 text-white/70 font-medium px-2.5 py-0.5 rounded-full border border-white/10">
                  {tag}
                </span>
              ))}
            </div>
            <span class="text-white/40 group-hover:text-white/80 group-hover:translate-x-0.5 transition-all text-lg">→</span>
          </div>
        </div>
      </a>

    </div>
  </div>

  <!-- ── Chapter List ────────────────────────────── -->
  <div class="space-y-5 mb-16">
    {chapters.map((ch) => (
      <div class={`relative group ${ch.status === 'coming' ? 'opacity-55' : ''}`}>
        {ch.status === 'published' ? (
          <a
            href={ch.href}
            class="card-lift block bg-white border border-stone-200 rounded-2xl p-5 sm:p-7 no-underline text-stone-900 hover:border-columbia-blue transition-all"
          >
            <div class="flex items-start gap-3 sm:gap-5">
              <div class="shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-columbia-navy flex items-center justify-center">
                <span class="font-display font-bold text-white text-sm">{ch.num}</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2 flex-wrap">
                  <h2 class="font-display font-bold text-base sm:text-lg text-stone-900 group-hover:text-columbia-navy transition-colors leading-snug">
                    {ch.title}
                  </h2>
                  {ch.date && (
                    <span class="shrink-0 text-[11px] text-stone-400 mt-0.5 hidden sm:inline">{ch.date}</span>
                  )}
                </div>
                <p class="mt-1.5 text-sm text-stone-500 leading-relaxed">{ch.desc}</p>
                <div class="mt-2.5 flex flex-wrap items-center gap-1.5">
                  {ch.tags.map((tag) => (
                    <span class="text-[10px] bg-columbia-light text-columbia-navy font-medium px-2.5 py-0.5 rounded-full">
                      {tag}
                    </span>
                  ))}
                  {ch.readTime && (
                    <span class="text-[11px] text-stone-400 ml-1">{ch.readTime}</span>
                  )}
                </div>
              </div>
              <span class="hidden sm:block shrink-0 text-columbia-blue opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all text-xl mt-2">→</span>
            </div>
          </a>
        ) : (
          <div class="bg-white border border-dashed border-stone-200 rounded-2xl p-5 sm:p-7">
            <div class="flex items-start gap-3 sm:gap-5">
              <div class="shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-stone-100 flex items-center justify-center">
                <span class="font-display font-bold text-stone-400 text-sm">{ch.num}</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h2 class="font-display font-bold text-lg text-stone-400 leading-snug">{ch.title}</h2>
                  <span class="text-[10px] bg-stone-100 text-stone-400 font-medium px-2.5 py-0.5 rounded-full">
                    即将上线
                  </span>
                </div>
                <p class="mt-2 text-sm text-stone-400 leading-relaxed max-w-2xl">{ch.desc}</p>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  {ch.tags.map((tag) => (
                    <span class="text-[10px] bg-stone-100 text-stone-400 font-medium px-2.5 py-0.5 rounded-full">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        )}
      </div>
    ))}
  </div>

  <!-- ── Coffee Chat CTA ──────────────────────────────── -->
  <div class="mb-14 mt-2">
    <div class="bg-white border border-stone-200 rounded-2xl px-8 py-7 flex flex-col sm:flex-row items-start sm:items-center gap-5">
      <div class="shrink-0 text-3xl leading-none">☕</div>
      <div class="flex-1 min-w-0">
        <p class="font-semibold text-stone-800 text-[0.95rem] leading-snug mb-1">
          对未来的职业方向感到迷茫？欢迎来聊
        </p>
        <p class="text-sm text-stone-500 leading-relaxed">
          无论是回国还是留美、投行还是公募、互联网大厂、转行还是深耕——如果你想找个聊过的人捋一捋思路，欢迎发邮件约 10–15 分钟 1v1 online coffee chat。记得带简历哦～
        </p>
      </div>
      <a
        href="mailto:yh3811@columbia.edu"
        class="shrink-0 inline-flex items-center gap-1.5 no-underline px-5 py-2 bg-columbia-navy text-white text-sm font-semibold rounded-full hover:bg-columbia-blue transition-colors whitespace-nowrap"
      >
        yh3811@columbia.edu →
      </a>
    </div>
  </div>

  <!-- ── Contribute CTA ─────────────────────────────── -->
  <section class="bg-columbia-navy rounded-2xl p-8 text-white text-center">
    <p class="font-display font-semibold text-lg mb-2">分享您的求职，求学，人生故事？</p>
    <p class="text-white/60 text-sm leading-relaxed mb-5 max-w-sm mx-auto">
      加入我们，一起点亮迷茫路上的那盏灯。<br />每一个真实的声音，都值得被听见。❤️
    </p>
    <a
      href="/join/"
      class="inline-block no-underline px-6 py-2.5 bg-white text-columbia-navy font-semibold text-sm rounded-full hover:bg-columbia-light transition-colors"
    >
      联系我 →
    </a>
  </section>

  </div><!-- end inner -->
  </div><!-- end full-width bg -->

</Base>
