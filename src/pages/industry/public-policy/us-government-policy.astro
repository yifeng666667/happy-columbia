    <div class="flex items-center gap-2 mb-4">
      <span class="text-[10px] uppercase tracking-[0.25em] bg-purple-50 text-purple-700 border border-purple-200 font-semibold px-3 py-1 rounded-full">US Government & Think Tanks</span>
