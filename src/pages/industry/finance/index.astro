    tags: ['Early Stage', 'Series A/B', 'Scout', 'LP/GP'],
    difficulty: '很难',
    diffColor: 'text-orange-600 bg-orange-50 border-orange-200',
    salary_us: '$80k–$200k',
    salary_cn: '国内参考',
  },
  {
