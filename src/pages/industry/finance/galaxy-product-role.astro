            <td class="p-3 border border-stone-200 text-emerald-600">↑ +508.20%</td>
          </tr>
          <tr>
            <td class="p-3 border border-stone-200 font-medium">投资银行业务</td>
            <td class="p-3 border border-stone-200 text-right">5.85亿</td>
