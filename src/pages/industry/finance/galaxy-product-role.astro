            <td class="p-3 border border-stone-200 text-right">23.23%</td>
            <td class="p-3 border border-stone-200 text-emerald-600">↑ +18.23%</td>
          </tr>
          <tr class="bg-stone-50">
            <td class="p-3 border border-stone-200 font-medium">机构业务</td>
