            <td class="p-3 border border-stone-200 text-right">45-80万</td>
          </tr>
          <tr>
            <td class="p-3 border border-stone-200 font-medium">7-12年</td>
            <td class="p-3 border border-stone-200">产品线负责人 / 资深产品经理</td>
            <td class="p-3 border border-stone-200">32-38</td>
            <td class="p-3 border border-stone-200 text-right">80-150万</td>
          </tr>
          <tr class="bg-stone-50">
            <td class="p-3 border border-stone-200 font-medium">12年以上</td>
            <td class="p-3 border border-stone-200">产品总经理 / 部门副总 / 财富管理总监</td>
