          <p class="text-xs text-stone-500">行业排名第一</p>
        </div>
        <div class="bg-white rounded-xl p-3 border border-stone-200">
          <p class="text-xs text-stone-400 mb-1">2024年净利润</p>
          <p class="font-bold text-columbia-navy text-lg">217.04亿元</p>
          <p class="text-xs text-stone-500">A+H股双上市</p>
