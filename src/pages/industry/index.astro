---
import Base from '../../layouts/Base.astro';

const industries = [
  {
    id: 'finance',
    href: '/industry/finance/',
    emoji: '🏦',
    title: '金融行业',
    titleEn: 'Finance',
    desc: '投行、PE、VC、对冲基金、资管、商业银行、证券研究、量化——从历史起源到中美职场全景',
    tags: ['投资银行', 'PE/VC', '对冲基金', '资产管理', '量化'],
    status: 'published',
    count: 8,
    color: 'amber',
  },
  {
    id: 'consulting',
    href: '/industry/consulting/',
    emoji: '📊',
    title: '咨询行业',
    titleEn: 'Consulting',
    desc: 'MBB管理咨询、四大、战略咨询、经济咨询——最受文商科青睐的行业，拆解真实日常与职业天花板',
    tags: ['McKinsey', 'BCG', 'Bain', '四大', '战略咨询'],
    status: 'published',
    count: 3,
    color: 'blue',
  },
  {
    id: 'tech-business',
    href: '/industry/tech-business/',
    emoji: '💻',
    title: '科技行业（商业岗）',
    titleEn: 'Tech — Business Roles',
    desc: '产品经理、商业分析、数据分析、科技公司战略BD——文科生进大厂的真实路径',
    tags: ['产品经理', '商业分析', 'Strategy & Ops', 'BD'],
    status: 'published',
    count: 4,
    color: 'green',
  },
  {
    id: 'public-policy',
    href: '/industry/public-policy/',
    emoji: '🌐',
    title: '公共政策与国际组织',
    titleEn: 'Public Policy & Intl Orgs',
    desc: 'IMF、世界银行、联合国、政府智库、NGO——如何进入国际组织，中美两条路径对比',
    tags: ['IMF', 'World Bank', 'UN', '智库', 'NGO'],
    status: 'coming',
    count: 0,
    color: 'purple',
  },
  {
    id: 'law',
    href: '/industry/law/',
    emoji: '⚖️',
    title: '法律行业',
    titleEn: 'Legal',
    desc: '美国律所、中国律所、企业法务内律——JD vs LLM，中美法律职业路径的本质差异',
    tags: ['律所', '内法', 'JD', 'LLM', '合规'],
    status: 'coming',
    count: 0,
    color: 'red',
  },
  {
    id: 'media-marketing',
    href: '/industry/media-marketing/',
    emoji: '📢',
    title: '传媒与市场营销',
    titleEn: 'Media & Marketing',
    desc: '新闻媒体、品牌公关、数字营销、内容创作——传统媒体衰退后的职业重构',
    tags: ['新闻媒体', '品牌公关', '数字营销', '内容'],
    status: 'coming',
    count: 0,
    color: 'pink',
  },
];

const colorMap: Record<string, { bg: string; text: string; border: string; dot: string }> = {
  amber:  { bg: 'bg-amber-50',  text: 'text-amber-700',  border: 'border-amber-200',  dot: 'bg-amber-400' },
  blue:   { bg: 'bg-blue-50',   text: 'text-blue-700',   border: 'border-blue-200',   dot: 'bg-blue-400' },
  green:  { bg: 'bg-emerald-50',text: 'text-emerald-700',border: 'border-emerald-200',dot: 'bg-emerald-400' },
  purple: { bg: 'bg-purple-50', text: 'text-purple-700', border: 'border-purple-200', dot: 'bg-purple-400' },
  red:    { bg: 'bg-red-50',    text: 'text-red-700',    border: 'border-red-200',    dot: 'bg-red-400' },
  pink:   { bg: 'bg-pink-50',   text: 'text-pink-700',   border: 'border-pink-200',   dot: 'bg-pink-400' },
};
---

<Base title="行业深度解析" hero={true}>

  <!-- Hero -->
  <section class="relative min-h-[58vh] flex flex-col justify-end overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1800&q=85"
        alt=""
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0" style="background: linear-gradient(160deg, rgba(6,18,36,0.88) 0%, rgba(11,44,86,0.80) 60%, rgba(4,12,28,0.92) 100%);"></div>
    </div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 w-full pb-14 pt-24 sm:pb-20 sm:pt-32">
      <p class="text-[11px] uppercase tracking-[0.3em] text-white/50 mb-3">Industry Analysis</p>
      <h1 class="font-display font-bold text-white leading-tight mb-4"
          style="font-size: clamp(1.75rem, 6vw, 3.5rem);">
        行业深度解析
      </h1>
      <p class="text-white/80 text-sm sm:text-[1.05rem] leading-relaxed mb-3 max-w-2xl">
        从历史起源、商业模式、职业路径，到中美两个市场的真实差异——给每一个还在思考方向的你。
      </p>
      <p class="text-white/45 text-xs sm:text-sm leading-relaxed max-w-xl">
        覆盖金融、咨询、科技商业岗、公共政策、法律、传媒等文科&商科主流方向。持续更新中。
      </p>
    </div>
  </section>

  <!-- Main -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14 sm:py-20">

    <!-- Intro callout -->
    <div class="mb-12 bg-columbia-light border border-columbia-blue/20 rounded-2xl px-6 py-5">
      <p class="text-columbia-navy/90 text-sm leading-relaxed" style="margin:0">
        <strong>这里不是职位描述（JD）的翻译</strong>，而是帮你建立对一个行业的完整认知框架：它为什么存在、钱从哪里来、真实工作是什么样、中美有哪些结构性差异、未来10年会怎么变。在投简历之前，先弄懂这个行业值不值得你花时间。
      </p>
    </div>

    <!-- Industry grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {industries.map((ind) => {
        const c = colorMap[ind.color];
        return (
          <a
            href={ind.status === 'published' ? ind.href : '#'}
            class={`group relative block rounded-2xl border bg-white p-6 transition-all no-underline ${ind.status === 'published' ? 'hover:shadow-lg hover:-translate-y-1 border-stone-200 cursor-pointer' : 'opacity-60 cursor-default border-stone-100'}`}
          >
            {ind.status === 'coming' && (
              <span class="absolute top-4 right-4 text-[10px] bg-stone-100 text-stone-400 font-medium px-2 py-0.5 rounded-full">
                即将上线
              </span>
            )}
            <div class="text-3xl mb-4">{ind.emoji}</div>
            <h2 class="font-display font-bold text-stone-900 text-lg leading-tight mb-1 group-hover:text-columbia-navy transition-colors">
              {ind.title}
            </h2>
            <p class="text-[11px] text-stone-400 mb-3">{ind.titleEn}</p>
            <p class="text-stone-500 text-sm leading-relaxed mb-4">{ind.desc}</p>
            <div class="flex flex-wrap gap-1.5">
              {ind.tags.map(tag => (
                <span class={`text-[10px] font-medium px-2 py-0.5 rounded-full ${c.bg} ${c.text} border ${c.border}`}>
                  {tag}
                </span>
              ))}
            </div>
            {ind.status === 'published' && (
              <p class="mt-4 text-[11px] text-columbia-blue font-medium group-hover:underline">
                {ind.count} 个细分方向 →
              </p>
            )}
          </a>
        );
      })}
    </div>

    <!-- Footer note -->
    <div class="mt-16 text-center text-stone-400 text-sm">
      <p>内容持续更新中 · 有行业想看？欢迎发邮件 <a href="mailto:yh3811@columbia.edu" class="text-columbia-blue hover:underline">yh3811@columbia.edu</a></p>
    </div>
  </div>
</Base>
