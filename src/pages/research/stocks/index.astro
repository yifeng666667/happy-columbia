---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';

let stocksEntries: any[] = [];
try {
  const all = await getCollection('research');
  stocksEntries = all
    .filter(e => e.data.category === 'stocks')
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
} catch (_) {}

const slugOf = (id: string) => id.split('/').slice(1).join('/').replace(/\.md$/, '');
---

<Base title="行业 & 板块研究">

  <!-- Password gate overlay -->
  <div
    id="lock-gate"
    class="fixed inset-0 z-50 flex items-center justify-center bg-stone-900/70 backdrop-blur-sm"
  >
    <div class="bg-white rounded-2xl shadow-2xl border border-stone-200 p-8 w-full max-w-sm mx-4 text-center">

      <!-- Lock icon -->
      <div class="w-14 h-14 rounded-full bg-stone-100 flex items-center justify-center mx-auto mb-5">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
             class="w-7 h-7 text-stone-500">
          <rect x="3" y="11" width="18" height="11" rx="2"/>
          <path d="M7 11V7a5 5 0 0110 0v4"/>
        </svg>
      </div>

      <h2 class="font-display font-bold text-xl text-stone-900 mb-1">行业 &amp; 板块研究</h2>
      <p class="text-stone-400 text-sm mb-6 leading-relaxed">
        此板块需要管理员授权后访问<br/>请输入访问密码继续
      </p>

      <form id="unlock-form" class="space-y-3">
        <input
          id="pw-input"
          type="password"
          placeholder="密 码"
          autocomplete="current-password"
          class="w-full px-4 py-2.5 rounded-lg border border-stone-300 text-sm text-center
                 tracking-[0.4em] focus:outline-none focus:ring-2 focus:ring-columbia-navy/20
                 focus:border-columbia-navy transition-colors"
        />
        <p id="pw-error" class="hidden text-red-500 text-xs">密码不正确，请重试</p>
        <button
          type="submit"
          class="w-full py-2.5 rounded-lg text-sm font-semibold text-white bg-columbia-navy
                 hover:bg-columbia-navy/90 transition-colors"
        >
          进入
        </button>
      </form>

      <div class="mt-5 pt-5 border-t border-stone-100">
        <a href="/research/" class="text-xs text-stone-400 hover:text-stone-700 transition-colors no-underline">
          ← 返回金融投研首页
        </a>
      </div>
    </div>
  </div>

  <!-- Protected content (revealed after unlock) -->
  <div id="stocks-content" class="hidden">

    <!-- Category hero banner -->
    <div
      class="-mx-6 -mt-14 mb-0 text-white px-6 pt-14 pb-12 relative overflow-hidden"
      style="background-image: linear-gradient(160deg, rgba(15,23,42,0.92) 0%, rgba(30,41,59,0.85) 100%), url('https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?auto=format&fit=crop&w=2560&q=80'); background-size: cover; background-position: center;"
    >
      <div class="relative z-10 max-w-3xl">
        <a href="/research/"
           class="inline-flex items-center gap-1.5 text-white/60 hover:text-white text-xs transition-colors no-underline mb-6 group">
          <span class="group-hover:-translate-x-0.5 transition-transform inline-block">←</span>
          金融投研
        </a>

        <p class="text-[11px] uppercase tracking-[0.25em] text-white/50 mb-3">Industry &amp; Sector Research</p>
        <h1 class="font-display font-bold text-3xl md:text-4xl leading-tight text-white">
          行业 &amp; 板块研究
        </h1>
        <p class="mt-3 text-white/65 leading-relaxed text-[0.9375rem] max-w-xl">
          行业深度研究与板块趋势追踪，需管理员授权访问
        </p>

        <div class="mt-5 flex items-center gap-5 text-sm">
          <div>
            <span class="text-white/40 text-xs uppercase tracking-wider">文章数量</span>
            <p class="text-white font-medium mt-0.5">{stocksEntries.length} 篇</p>
          </div>
          <button
            id="lock-btn"
            class="flex items-center gap-1.5 text-white/40 hover:text-white/70 text-xs transition-colors"
          >
            <svg viewBox="0 0 14 14" fill="currentColor" class="w-3 h-3">
              <path d="M10 1a3 3 0 00-3 3v1.5H3.5a1 1 0 00-1 1V12a1 1 0 001 1H10.5a1 1 0 001-1V6.5a1 1 0 00-1-1H8.5V4a1.5 1.5 0 013 0 .75.75 0 001.5 0A3 3 0 0010 1z"/>
            </svg>
            重新锁定
          </button>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 mb-8 flex items-start gap-2 bg-amber-50 border border-amber-200 rounded-xl px-4 py-3">
      <svg viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 shrink-0 mt-0.5 text-amber-500">
        <path d="M6.457 1.047c.345-.79 1.425-.79 1.77 0l1.07 2.46 2.65.23c.85.074 1.192 1.133.538 1.696L9.2 6.87l.63 2.614c.2.836-.704 1.493-1.43 1.04L6 9.115l-2.4 1.41c-.726.453-1.63-.204-1.43-1.04L2.8 6.87.782 5.13c-.654-.563-.312-1.622.538-1.696l2.65-.23L5.23.745z"/>
      </svg>
      <p class="text-xs text-amber-700">
        以下内容均以个人<strong class="font-semibold">学习研究</strong>为目的，
        <strong class="font-semibold">不构成任何投资建议</strong>，不代表对任何证券的买卖推荐。
      </p>
    </div>

    <!-- Article TOC -->
    <section>
      <p class="text-[11px] uppercase tracking-[0.25em] text-stone-400 mb-5">
        {stocksEntries.length > 0 ? `共 ${stocksEntries.length} 篇 · 按时间倒序` : '文章列表'}
      </p>

      {stocksEntries.length === 0 ? (
        <div class="border border-dashed border-stone-200 rounded-xl px-5 py-16 text-xs text-stone-400 text-center">
          <p class="font-medium mb-1">暂无文章</p>
          <p class="text-stone-300">内容持续整理中</p>
        </div>
      ) : (
        <div class="space-y-2">
          {stocksEntries.map((entry, i) => (
            <a
              href={`/research/stocks/${slugOf(entry.id)}/`}
              class="card-lift flex items-center gap-5 bg-white border border-stone-200 border-l-4 border-l-stone-300 rounded-xl px-5 py-4 no-underline text-stone-900 group"
            >
              <span class="shrink-0 w-8 h-8 rounded-full bg-stone-100 group-hover:bg-columbia-light flex items-center justify-center text-xs font-mono font-semibold text-stone-400 group-hover:text-columbia-navy transition-colors">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="flex-1 font-medium leading-snug group-hover:text-columbia-navy transition-colors">
                {entry.data.title}
              </span>
              <span class="shrink-0 text-xs text-stone-400">{entry.data.date}</span>
              <span class="shrink-0 text-columbia-blue opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all text-sm">
                阅读 →
              </span>
            </a>
          ))}
        </div>
      )}
    </section>

  </div>
</Base>

<script>
  const SESSION_KEY = 'hc_stocks_unlocked';
  const CORRECT_PW  = '0502';

  const gate    = document.getElementById('lock-gate')!;
  const content = document.getElementById('stocks-content')!;
  const form    = document.getElementById('unlock-form')!;
  const input   = document.getElementById('pw-input') as HTMLInputElement;
  const errMsg  = document.getElementById('pw-error')!;
  const lockBtn = document.getElementById('lock-btn');

  function showContent() {
    gate.style.display = 'none';
    content.classList.remove('hidden');
  }

  if (sessionStorage.getItem(SESSION_KEY) === 'true') showContent();

  form.addEventListener('submit', e => {
    e.preventDefault();
    if (input.value === CORRECT_PW) {
      sessionStorage.setItem(SESSION_KEY, 'true');
      errMsg.classList.add('hidden');
      showContent();
    } else {
      errMsg.classList.remove('hidden');
      input.value = '';
      input.focus();
    }
  });

  lockBtn?.addEventListener('click', () => {
    sessionStorage.removeItem(SESSION_KEY);
    content.classList.add('hidden');
    gate.style.display = 'flex';
    input.value = '';
  });
</script>
