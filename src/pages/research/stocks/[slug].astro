---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  let all: any[] = [];
  try { all = await getCollection('research'); } catch (_) { return []; }

  const entries = all
    .filter(e => e.data.category === 'stocks')
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

  return entries.map((entry, i) => {
    const parts = entry.id.split('/');
    const slug = parts.slice(1).join('/').replace(/\.md$/, '');
    return {
      params: { slug },
      props: {
        entry,
        prev: entries[i + 1] ?? null,
        next: entries[i - 1] ?? null,
        total: entries.length,
        index: i,
      },
    };
  });
}

const { entry, prev, next, total, index } = Astro.props;
const { Content } = await entry.render();

const slugOf = (id: string) => id.split('/').slice(1).join('/').replace(/\.md$/, '');
const progress = Math.round(((index + 1) / total) * 100);
---

<Base title={entry.data.title}>

  <!-- Auth gate overlay (shown until session verified) -->
  <div id="lock-gate" class="fixed inset-0 z-50 flex items-center justify-center bg-stone-900/70 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl border border-stone-200 p-8 w-full max-w-sm mx-4 text-center">
      <div class="w-14 h-14 rounded-full bg-stone-100 flex items-center justify-center mx-auto mb-5">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7 text-stone-500">
          <rect x="3" y="11" width="18" height="11" rx="2"/>
          <path d="M7 11V7a5 5 0 0110 0v4"/>
        </svg>
      </div>
      <h2 class="font-display font-bold text-xl text-stone-900 mb-1">访问受限</h2>
      <p class="text-stone-400 text-sm mb-6">请输入密码以访问此内容</p>
      <form id="unlock-form" class="space-y-3">
        <input
          id="pw-input" type="password" placeholder="密 码"
          autocomplete="current-password"
          class="w-full px-4 py-2.5 rounded-lg border border-stone-300 text-sm text-center
                 tracking-[0.4em] focus:outline-none focus:ring-2 focus:ring-columbia-navy/20
                 focus:border-columbia-navy transition-colors"
        />
        <p id="pw-error" class="hidden text-red-500 text-xs">密码不正确，请重试</p>
        <button type="submit"
          class="w-full py-2.5 rounded-lg text-sm font-semibold text-white bg-columbia-navy hover:bg-columbia-navy/90 transition-colors">
          进入
        </button>
      </form>
      <div class="mt-5 pt-5 border-t border-stone-100">
        <a href="/research/stocks/" class="text-xs text-stone-400 hover:text-stone-700 transition-colors no-underline">← 返回列表</a>
      </div>
    </div>
  </div>

  <!-- Protected article content -->
  <div id="article-content" class="hidden">

    <!-- Reading header strip -->
    <div class="-mx-6 -mt-14 mb-8 bg-white border-b border-stone-200 px-6 pt-14 pb-5">
      <div class="max-w-3xl">
        <a href="/research/stocks/"
           class="inline-flex items-center gap-1.5 text-stone-400 hover:text-columbia-navy text-xs transition-colors no-underline mb-3 group">
          <span class="group-hover:-translate-x-0.5 transition-transform inline-block">←</span>
          个股 &amp; 板块
        </a>
        <h1 class="font-display font-bold text-2xl md:text-3xl text-stone-900 leading-tight">
          {entry.data.title}
        </h1>
        {entry.data.summary && (
          <p class="mt-2 text-stone-500 text-sm leading-relaxed">{entry.data.summary}</p>
        )}
        <div class="mt-4 flex items-center gap-3">
          <div class="flex-1 h-1 bg-stone-100 rounded-full overflow-hidden">
            <div class="h-full bg-columbia-blue rounded-full" style={`width:${progress}%`}></div>
          </div>
          <span class="text-xs text-stone-400 shrink-0">{index + 1} / {total}</span>
        </div>
        <p class="mt-3 text-[11px] text-amber-600 flex items-center gap-1.5">
          <svg viewBox="0 0 12 12" fill="currentColor" class="w-3 h-3 shrink-0">
            <path d="M5.23.745c.345-.79 1.425-.79 1.77 0l1.07 2.46 2.65.23c.85.074 1.192 1.133.538 1.696L9.2 6.87l.63 2.614c.2.836-.704 1.493-1.43 1.04L6 9.115l-2.4 1.41c-.726.453-1.63-.204-1.43-1.04L2.8 6.87.782 5.13c-.654-.563-.312-1.622.538-1.696l2.65-.23L5.23.745z"/>
          </svg>
          以学习研究为目的 · 不构成投资建议
        </p>
      </div>
    </div>

    {entry.data.tags && entry.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6 max-w-3xl">
        {entry.data.tags.map((tag: string) => (
          <span class="text-xs px-2.5 py-1 rounded-full bg-stone-100 text-stone-500">{tag}</span>
        ))}
      </div>
    )}

    <!-- Article body -->
    <article
      class="prose-reading prose prose-stone max-w-3xl
             prose-headings:font-display prose-headings:font-bold prose-headings:tracking-tight
             prose-h1:text-3xl prose-h1:mb-6
             prose-h2:text-xl prose-h2:mt-12 prose-h2:pb-2 prose-h2:border-b prose-h2:border-stone-200 prose-h2:text-columbia-navy
             prose-h3:text-base prose-h3:mt-8 prose-h3:text-stone-800
             prose-p:leading-[1.9]
             prose-a:text-columbia-blue prose-a:no-underline hover:prose-a:underline
             prose-strong:text-stone-900
             prose-code:before:content-none prose-code:after:content-none
             prose-code:bg-stone-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
             prose-code:text-stone-800 prose-code:font-normal prose-code:text-[0.85em]
             prose-pre:bg-stone-900
             prose-blockquote:border-l-4 prose-blockquote:border-columbia-blue
             prose-blockquote:bg-columbia-light/30 prose-blockquote:px-5 prose-blockquote:py-3 prose-blockquote:rounded-r-lg
             prose-blockquote:text-stone-700 prose-blockquote:not-italic
             prose-li:leading-[1.85]
             prose-table:text-sm
             prose-th:bg-columbia-light prose-th:text-columbia-navy"
    >
      <Content />
    </article>

    <!-- Prev / Next -->
    <nav class="mt-16 pt-8 border-t border-stone-200 grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl">
      {prev ? (
        <a href={`/research/stocks/${slugOf(prev.id)}/`}
           class="card-lift group flex flex-col bg-white border border-stone-200 border-l-4 border-l-stone-300 rounded-xl px-5 py-4 no-underline text-stone-900">
          <span class="text-[10px] uppercase tracking-widest text-stone-400 mb-1.5 flex items-center gap-1">
            <span class="group-hover:-translate-x-0.5 transition-transform inline-block">←</span> 上一篇
          </span>
          <span class="font-medium text-sm leading-snug group-hover:text-columbia-navy transition-colors">
            {prev.data.title}
          </span>
        </a>
      ) : <span />}

      {next ? (
        <a href={`/research/stocks/${slugOf(next.id)}/`}
           class="card-lift group flex flex-col bg-white border border-stone-200 border-l-4 border-l-stone-300 rounded-xl px-5 py-4 no-underline text-stone-900 sm:text-right sm:items-end">
          <span class="text-[10px] uppercase tracking-widest text-stone-400 mb-1.5 flex items-center gap-1 sm:flex-row-reverse">
            下一篇 <span class="group-hover:translate-x-0.5 transition-transform inline-block">→</span>
          </span>
          <span class="font-medium text-sm leading-snug group-hover:text-columbia-navy transition-colors">
            {next.data.title}
          </span>
        </a>
      ) : <span />}
    </nav>

    <div class="mt-8 max-w-3xl text-center">
      <a href="/research/stocks/"
         class="inline-flex items-center gap-2 text-xs text-stone-400 hover:text-columbia-navy transition-colors no-underline">
        ↑ 返回《个股 &amp; 板块》列表
      </a>
    </div>

  </div>
</Base>

<script>
  const SESSION_KEY = 'hc_stocks_unlocked';
  const CORRECT_PW  = '0502';

  const gate    = document.getElementById('lock-gate')!;
  const content = document.getElementById('article-content')!;
  const form    = document.getElementById('unlock-form')!;
  const input   = document.getElementById('pw-input') as HTMLInputElement;
  const errMsg  = document.getElementById('pw-error')!;

  function show() { gate.style.display = 'none'; content.classList.remove('hidden'); }
  if (sessionStorage.getItem(SESSION_KEY) === 'true') show();

  form.addEventListener('submit', e => {
    e.preventDefault();
    if (input.value === CORRECT_PW) {
      sessionStorage.setItem(SESSION_KEY, 'true');
      errMsg.classList.add('hidden');
      show();
    } else {
      errMsg.classList.remove('hidden');
      input.value = '';
      input.focus();
    }
  });
</script>
